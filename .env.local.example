# GoHighLevel Integration
# ========================
# Option 1 (Recommended): Webhook URL from GHL Workflow
# Go to GHL > Automation > Workflows > Create Workflow > Trigger: Inbound Webhook
# Copy the webhook URL here:
NEXT_PUBLIC_GHL_WEBHOOK_URL=
GHL_WEBHOOK_URL=

# Option 2: Direct API Integration
# Go to GHL > Settings > Business Profile > API Keys
GHL_API_KEY=
GHL_LOCATION_ID=

# Site URL (for sitemap and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://saddlewoodcontracting.com
